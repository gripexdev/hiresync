# ─────────────────────────────────────────────────────────────────────────────
# HireSync Backend — Environment Variables
# Copy this file to .env, fill in the required values, then run:
#   Windows:  set -a && . .env && set +a   (Git Bash / WSL)
#   Linux:    set -a; source .env; set +a
# Or set them as system env vars before running the JAR / IDE.
# ─────────────────────────────────────────────────────────────────────────────

# ── REQUIRED ──────────────────────────────────────────────────────────────────

# OpenRouter API key — get a free one at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# JWT signing secret — minimum 64 characters, generate with:
#   openssl rand -base64 64
JWT_SECRET=your-64-character-minimum-base64-secret-here

# ── DATABASE (defaults match docker-compose.yml) ──────────────────────────────
DB_URL=jdbc:postgresql://localhost:5432/hiresync
DB_USER=hiresync
DB_PASS=hiresync123

# ── RABBITMQ (defaults match docker-compose.yml) ──────────────────────────────
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=hiresync
RABBITMQ_PASS=hiresync123

# ── OPTIONAL OVERRIDES ────────────────────────────────────────────────────────

# Server port (default: 8080)
# SERVER_PORT=8080

# JWT token lifetime in ms (default: 86400000 = 24h)
# JWT_EXPIRATION_MS=86400000

# LLM model to use via OpenRouter (default: google/gemma-4-31b-it:free)
# OPENROUTER_MODEL=google/gemma-4-31b-it:free

# Directory to store uploaded CV PDFs (default: ./uploads/cvs)
# CV_UPLOAD_DIR=./uploads/cvs

# Allowed CORS origins — comma-separated (default: localhost:4200,4201)
# CORS_ORIGINS=http://localhost:4200,http://localhost:4201
