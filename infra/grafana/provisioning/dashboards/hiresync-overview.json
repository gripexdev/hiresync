{
  "title": "HireSync — Vue d'ensemble",
  "uid": "hiresync-overview",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Débit HTTP (req/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{job=\"hiresync-backend\"}[1m])) by (uri, status)",
          "legendFormat": "{{uri}} [{{status}}]"
        }
      ]
    },
    {
      "id": 2,
      "title": "Latence moyenne HTTP (s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_sum{job=\"hiresync-backend\"}[1m])) by (uri) / sum(rate(http_server_requests_seconds_count{job=\"hiresync-backend\"}[1m])) by (uri)",
          "legendFormat": "{{uri}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "Mémoire JVM (heap)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "jvm_memory_used_bytes{job=\"hiresync-backend\", area=\"heap\"}",
          "legendFormat": "used {{id}}"
        },
        {
          "expr": "jvm_memory_max_bytes{job=\"hiresync-backend\", area=\"heap\"}",
          "legendFormat": "max {{id}}"
        }
      ]
    },
    {
      "id": 4,
      "title": "CPU process (backend)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "process_cpu_usage{job=\"hiresync-backend\"}",
          "legendFormat": "CPU usage"
        }
      ]
    },
    {
      "id": 5,
      "title": "RabbitMQ — messages en attente par file",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rabbitmq_queue_messages_ready",
          "legendFormat": "{{queue}}"
        }
      ]
    },
    {
      "id": 6,
      "title": "RabbitMQ — consommateurs actifs",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rabbitmq_queue_consumers",
          "legendFormat": "{{queue}}"
        }
      ]
    },
    {
      "id": 7,
      "title": "PostgreSQL — connexions actives",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "pg_stat_database_numbackends{datname=\"hiresync\"}",
          "legendFormat": "connexions"
        }
      ]
    },
    {
      "id": 8,
      "title": "Disponibilité des cibles (up)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "up",
          "legendFormat": "{{job}}"
        }
      ]
    }
  ]
}
