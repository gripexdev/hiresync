# ── Angular frontend ──────────────────────────────────────────────────────────
hiresync/node_modules/
hiresync/dist/
hiresync/.angular/
hiresync/*.tsbuildinfo

# ── Spring Boot backend (future) ──────────────────────────────────────────────
backend/target/
backend/.mvn/wrapper/maven-wrapper.jar
backend/*.log

# ── Environment / secrets ─────────────────────────────────────────────────────
.env
backend/.env
.env.*
!.env.example
!backend/.env.example
application-local.properties
application-local.yml
# application.yml contains real secrets — never commit it
# use application.yml.example as the template
backend/src/main/resources/application.yml
!backend/src/main/resources/application.yml.example

# ── CV uploads (binary files, not for git) ────────────────────────────────────
backend/uploads/

# ── IDEs ──────────────────────────────────────────────────────────────────────
.idea/
*.iml
.vscode/
*.suo
*.user

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── PFE report (local deliverable, not part of the app) ──────────────────────
rapport-pfe/
